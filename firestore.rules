rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Security Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Companion device match block
    match /devices/{deviceId} {
      allow read, write: if true;
    }

    // 3. User Data fortress & Subcollection Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /profiles/{profileId} {
        allow get: if isOwner(userId) && isValidId(profileId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(profileId);
      }

      match /logs/{logId} {
        allow get: if isOwner(userId) && isValidId(logId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(logId);
      }

      match /dangerousEvents/{eventId} {
        allow get: if isOwner(userId) && isValidId(eventId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(eventId);
      }

      match /safeZones/{zoneId} {
        allow get: if isOwner(userId) && isValidId(zoneId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(zoneId);
      }

      match /chats/{chatId} {
        allow get: if isOwner(userId) && isValidId(chatId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(chatId);
      }
    }
  }
}
